---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getTranslations, getSupportedLangs } from '../../utils/i18n';
import type { Lang } from '../../utils/i18n';
import {
  Brain,
  Zap,
  Layers,
  BarChart,
  Home,
  Link as LinkIcon,
  ExternalLink,
  Github,
  TrendingUp,
} from 'lucide-astro';

export async function getStaticPaths() {
  return getSupportedLangs().map(lang => ({
    params: { lang },
    props: { lang },
  }));
}

interface Props {
  lang: Lang;
}

type ProjectLinkType = 'website' | 'repository' | 'blog';

interface ProjectLink {
  type: ProjectLinkType;
  url: string;
  label: string;
}

interface ProjectItem {
  name: string;
  period: string;
  industry: string;
  role?: string;
  tagline: string;
  description: string[];
  industries: string;
  tech: string;
  impact: string;
  featured?: boolean;
  links?: ProjectLink[];
}

interface ProjectsTranslations {
  meta: {
    title: string;
    description: string;
  };
  hero: {
    title: string;
    subtitle: string;
  };
  intro: string;
  company: string;
  role: string;
  labels: {
    industries: string;
    tech: string;
    impact: string;
    website: string;
    repository: string;
    blog: string;
  };
  projects: ProjectItem[];
}

const { lang } = Astro.props;
const t = await getTranslations<ProjectsTranslations>('projects', lang);

const iconMap: Record<string, any> = {
  entAIngine: Brain,
  entAIgent: Zap,
  'Flowhive AI': Layers,
  'Flowhive VC': BarChart,
  'Valuation Engine': Home,
  KnowledgeX: LinkIcon,
  'RP-Matcher': BarChart,
  'Prompt Wizard & Testbed': Zap,
};
---

<BaseLayout title={t.meta.title} description={t.meta.description} lang={lang}>
  <section class="projects-hero">
    <div class="container">
      <h1>{t.hero.title}</h1>
      <p class="projects-subtitle">{t.hero.subtitle}</p>
    </div>
  </section>

  <section class="projects-section">
    <div class="container">
      <div class="projects-intro">
        <p>
          {t.intro.split('{company}')[0]}
          <strong>{t.company}</strong>
          {t.intro.split('{company}')[1]}
        </p>
      </div>

      <div class="projects-list">
        {
          t.projects.map(project => {
            const Icon = iconMap[project.name];
            const isFeatured = (project as any).featured === true;
            const techTags = project.tech.split(',').map(t => t.trim());
            return (
              <article class={`project-card ${isFeatured ? 'project-card--featured' : ''}`}>
                {isFeatured && <div class="featured-badge">Flagship Product</div>}
                <div class="project-header">
                  <div class="project-title-group">
                    <h2 class="project-name">
                      <span class="project-icon">
                        {Icon && <Icon size={24} />}
                      </span>
                      {project.name}
                    </h2>
                    <div class="project-meta">
                      <span class="project-period">{project.period}</span>
                      <span class="project-role">{project.role ?? t.role}</span>
                      <span class="project-industry">{project.industry}</span>
                    </div>
                  </div>
                </div>

                <div class="project-content">
                  <p class="project-tagline">{project.tagline}</p>
                  {project.description.map(para => (
                    <p>{para}</p>
                  ))}
                </div>

                <div class="project-impact-box">
                  <div class="impact-icon">
                    <TrendingUp size={18} />
                  </div>
                  <div class="impact-text">
                    <strong>{t.labels.impact}</strong> {project.impact}
                  </div>
                </div>

                <div class="project-details">
                  <div class="project-tech-tags">
                    <strong class="detail-label">{t.labels.tech}</strong>
                    <div class="tech-pills">
                      {techTags.map(tag => (
                        <span class="tech-pill">{tag}</span>
                      ))}
                    </div>
                  </div>
                  <div class="project-industries-row">
                    <strong class="detail-label">{t.labels.industries}</strong>
                    <span>{project.industries}</span>
                  </div>
                </div>

                {project.links && project.links.length > 0 && (
                  <div class="project-links">
                    {project.links.map(link => (
                      <a
                        href={link.url}
                        target="_blank"
                        rel="noopener noreferrer"
                      >
                        {link.type === 'website' && <ExternalLink size={16} />}
                        {link.type === 'repository' && <Github size={16} />}
                        {link.type === 'blog' && <ExternalLink size={16} />}
                        {link.label}
                      </a>
                    ))}
                  </div>
                )}
              </article>
            );
          })
        }
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Hero */
  .projects-hero {
    padding: var(--space-8) 0;
    background: linear-gradient(
      135deg,
      var(--bg) 0%,
      oklch(from var(--primary) l c h / 0.05) 30%,
      oklch(from var(--accent) l c h / 0.03) 60%,
      var(--muted) 100%
    );
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .projects-hero::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: radial-gradient(
      ellipse at top right,
      oklch(from var(--primary) l c h / 0.08) 0%,
      transparent 50%
    );
    pointer-events: none;
    z-index: 0;
  }

  .projects-hero .container {
    position: relative;
    z-index: 1;
  }

  .projects-hero h1 {
    font-size: var(--font-size-hero);
    margin-bottom: var(--space-3);
    background: linear-gradient(
      135deg,
      var(--text) 0%,
      var(--primary) 50%,
      var(--text) 100%
    );
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    background-size: 200% auto;
    animation: gradient-shift 8s ease infinite;
  }

  @keyframes gradient-shift {
    0%,
    100% {
      background-position: 0% center;
    }
    50% {
      background-position: 100% center;
    }
  }

  .projects-subtitle {
    font-size: var(--font-size-xl);
    background: linear-gradient(135deg, var(--primary) 0%, var(--accent) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    margin-bottom: 0;
    font-weight: var(--font-weight-bold);
    max-width: var(--content-width);
    margin-left: auto;
    margin-right: auto;
  }

  /* Section */
  .projects-section {
    padding: var(--space-8) 0;
    background: linear-gradient(
      180deg,
      var(--bg) 0%,
      oklch(from var(--muted) l c h / 0.3) 50%,
      var(--bg) 100%
    );
  }

  .projects-intro {
    text-align: center;
    padding: var(--space-4) 0 var(--space-6) 0;
    margin-bottom: var(--space-6);
    position: relative;
  }

  .projects-intro::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 80px;
    height: 2px;
    background: linear-gradient(90deg, var(--primary), var(--accent));
    border-radius: 1px;
  }

  .projects-intro p {
    font-size: var(--font-size-lg);
    color: var(--text);
    opacity: 0.9;
    margin: 0;
  }

  .projects-intro strong {
    color: var(--primary);
    font-weight: var(--font-weight-bold);
  }

  /* Project list */
  .projects-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-7);
  }

  /* Project Card */
  .project-card {
    background: linear-gradient(
      135deg,
      var(--bg) 0%,
      oklch(from var(--primary) l c h / 0.02) 100%
    );
    border: 1px solid var(--border);
    border-radius: var(--radius-l);
    padding: var(--space-6) var(--space-7);
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
  }

  .project-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(
      90deg,
      var(--primary),
      var(--accent),
      var(--primary)
    );
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .project-card:hover {
    border-color: oklch(from var(--primary) l c h / 0.25);
    box-shadow:
      0 8px 24px oklch(from var(--primary) l c h / 0.1),
      var(--shadow-2);
    transform: translateY(-2px);
  }

  .project-card:hover::before {
    opacity: 1;
  }

  /* Featured card */
  .project-card--featured {
    border-color: oklch(from var(--primary) l c h / 0.2);
    background: linear-gradient(
      135deg,
      var(--bg) 0%,
      oklch(from var(--primary) l c h / 0.04) 50%,
      oklch(from var(--accent) l c h / 0.02) 100%
    );
    box-shadow: 0 4px 16px oklch(from var(--primary) l c h / 0.08);
  }

  .project-card--featured::before {
    opacity: 1;
    height: 4px;
  }

  .project-card--featured:hover {
    box-shadow:
      0 12px 32px oklch(from var(--primary) l c h / 0.15),
      var(--shadow-3);
  }

  .featured-badge {
    display: inline-flex;
    align-items: center;
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-bold);
    text-transform: uppercase;
    letter-spacing: 1px;
    color: white;
    background: linear-gradient(135deg, var(--primary) 0%, var(--accent) 100%);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-s);
    margin-bottom: var(--space-3);
    position: relative;
    z-index: 1;
  }

  /* Header */
  .project-header {
    margin-bottom: var(--space-4);
  }

  .project-title-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .project-name {
    font-size: var(--font-size-2xl);
    background: linear-gradient(135deg, var(--primary) 0%, var(--accent) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    margin: 0;
    font-weight: var(--font-weight-bold);
    line-height: 1.2;
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .project-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: var(--radius-m);
    background: linear-gradient(
      135deg,
      oklch(from var(--primary) l c h / 0.1) 0%,
      oklch(from var(--accent) l c h / 0.05) 100%
    );
    color: var(--primary);
    transition: all 0.3s ease;
    flex-shrink: 0;
  }

  .project-card:hover .project-icon {
    transform: scale(1.1);
    background: linear-gradient(
      135deg,
      oklch(from var(--primary) l c h / 0.15) 0%,
      oklch(from var(--accent) l c h / 0.1) 100%
    );
    color: var(--accent);
  }

  .project-meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    align-items: center;
  }

  .project-period,
  .project-industry {
    font-size: var(--font-size-sm);
    color: var(--text);
    opacity: 0.75;
    font-weight: var(--font-weight-normal);
    padding: 3px var(--space-2);
    background: var(--muted);
    border-radius: var(--radius-s);
  }

  .project-role {
    font-size: var(--font-size-sm);
    color: white;
    font-weight: var(--font-weight-bold);
    padding: 3px var(--space-2);
    background: linear-gradient(135deg, var(--primary) 0%, var(--accent) 100%);
    border-radius: var(--radius-s);
  }

  /* Content */
  .project-tagline {
    font-size: var(--font-size-lg);
    color: var(--text);
    font-weight: var(--font-weight-bold);
    margin-bottom: var(--space-3);
    font-style: italic;
    position: relative;
    z-index: 1;
    opacity: 0.85;
  }

  .project-content {
    margin-bottom: var(--space-5);
  }

  .project-content p {
    margin: 0;
    line-height: 1.7;
    font-size: var(--font-size-base);
    color: var(--text);
    margin-bottom: var(--space-3);
  }

  .project-content p:last-child {
    margin-bottom: 0;
  }

  /* Impact callout */
  .project-impact-box {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    padding: var(--space-4);
    margin-bottom: var(--space-5);
    background: linear-gradient(
      135deg,
      oklch(from var(--primary) l c h / 0.06) 0%,
      oklch(from var(--accent) l c h / 0.03) 100%
    );
    border-left: 3px solid var(--primary);
    border-radius: 0 var(--radius-m) var(--radius-m) 0;
    position: relative;
    z-index: 1;
  }

  .impact-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--primary) 0%, var(--accent) 100%);
    color: white;
    flex-shrink: 0;
    margin-top: 1px;
  }

  .impact-text {
    font-size: var(--font-size-sm);
    line-height: 1.6;
    color: var(--text);
  }

  .impact-text strong {
    color: var(--primary);
    font-weight: var(--font-weight-bold);
    display: block;
    margin-bottom: 2px;
    font-size: var(--font-size-xs);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  /* Details section */
  .project-details {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    position: relative;
    z-index: 1;
  }

  .detail-label {
    display: block;
    color: var(--primary);
    font-weight: var(--font-weight-bold);
    font-size: var(--font-size-xs);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: var(--space-2);
  }

  /* Tech pills */
  .tech-pills {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .tech-pill {
    display: inline-block;
    font-size: var(--font-size-xs);
    padding: 3px 10px;
    border-radius: 100px;
    background: linear-gradient(
      135deg,
      oklch(from var(--primary) l c h / 0.08) 0%,
      oklch(from var(--accent) l c h / 0.04) 100%
    );
    border: 1px solid oklch(from var(--primary) l c h / 0.15);
    color: var(--text);
    font-weight: var(--font-weight-normal);
    white-space: nowrap;
    transition: all 0.2s ease;
  }

  .tech-pill:hover {
    background: linear-gradient(
      135deg,
      oklch(from var(--primary) l c h / 0.15) 0%,
      oklch(from var(--accent) l c h / 0.08) 100%
    );
    border-color: oklch(from var(--primary) l c h / 0.3);
  }

  .project-industries-row {
    font-size: var(--font-size-sm);
    line-height: 1.6;
    color: var(--text);
    opacity: 0.8;
  }

  /* Links */
  .project-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-5);
    padding-top: var(--space-4);
    border-top: 1px solid var(--border);
    position: relative;
    z-index: 1;
  }

  .project-links a {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--primary);
    font-weight: var(--font-weight-bold);
    font-size: var(--font-size-sm);
    text-decoration: none;
    padding: var(--space-2) var(--space-4);
    border: 1px solid oklch(from var(--primary) l c h / 0.25);
    border-radius: var(--radius-m);
    transition: all 0.3s ease;
    background: var(--bg);
    position: relative;
    overflow: hidden;
  }

  .project-links a::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(255, 255, 255, 0.2),
      transparent
    );
    transition: left 0.5s ease;
  }

  .project-links a:hover {
    background: linear-gradient(135deg, var(--primary) 0%, var(--accent) 100%);
    color: white;
    border-color: var(--primary);
    text-decoration: none;
    transform: translateY(-2px);
    box-shadow: 0 4px 12px oklch(from var(--primary) l c h / 0.3);
  }

  .project-links a:hover::before {
    left: 100%;
  }

  .project-links a:focus-visible {
    outline: 2px solid var(--primary);
    outline-offset: 2px;
  }

  .project-links a svg {
    flex-shrink: 0;
  }

  /* Responsive */
  @media (max-width: 600px) {
    .project-card {
      padding: var(--space-4);
    }

    .project-name {
      font-size: var(--font-size-xl);
    }

    .project-icon {
      width: 32px;
      height: 32px;
    }

    .project-meta {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-2);
    }

    .project-impact-box {
      padding: var(--space-3);
    }

    .project-links {
      flex-direction: column;
    }

    .project-links a {
      width: 100%;
      justify-content: center;
    }
  }
</style>
