---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Picture } from 'astro:assets';
import {
  Brain,
  Cloud,
  Shield,
  Users,
  Code,
  Languages,
  Award,
  GraduationCap,
  Download,
  Quote,
} from 'lucide-astro';
import { getTranslations, getSupportedLangs } from '../../utils/i18n';
import type { Lang } from '../../utils/i18n';
import headshotImage from '../../assets/images/headshot.jpg';

export async function getStaticPaths() {
  return getSupportedLangs().map(lang => ({
    params: { lang },
    props: { lang },
  }));
}

interface Props {
  lang: Lang;
}

interface AboutTimelineItem {
  date: string;
  title: string;
  company: string;
  description: string;
  hasReference?: boolean;
  referenceText?: string;
}

type AboutAwardType = 'featured' | 'scholarship';

interface AboutAwardItem {
  type: AboutAwardType;
  title: string;
  subtitle: string;
  date: string;
  description: string;
}

interface AboutTranslations {
  meta: {
    title: string;
    description: string;
  };
  hero: {
    title: string;
    subtitle: string;
  };
  downloads: {
    title: string;
    cv: string;
  };
  bio: {
    paragraphs: string[];
  };
  outsideWork: {
    title: string;
    paragraphs: string[];
  };
  philosophy: {
    title: string;
    paragraphs: string[];
  };
  career: {
    title: string;
    paragraphs: string[];
  };
  specializations: {
    title: string;
    categories: Array<{
      title: string;
      items: string[];
    }>;
  };
  timeline: {
    title: string;
    items: AboutTimelineItem[];
  };
  awards: {
    title: string;
    items: AboutAwardItem[];
  };
}

const { lang } = Astro.props;
const t = await getTranslations<AboutTranslations>('about', lang);

const skillIcons = [Brain, Cloud, Shield, Users, Code, Languages];

function isListHtml(value: unknown): value is string {
  if (typeof value !== 'string') return false;
  const trimmed = value.trim();
  return trimmed.startsWith('<ul') || trimmed.startsWith('<ol');
}
---

<BaseLayout title={t.meta.title} description={t.meta.description} lang={lang}>
  <section class="about-hero">
    <div class="container">
      <h1>{t.hero.title}</h1>
      <p class="about-subtitle">{t.hero.subtitle}</p>
    </div>
  </section>

  <section class="about-content">
    <div class="container content">
      <!-- Bio with photo -->
      <div class="bio-section bio-intro">
        <div class="bio-layout">
          <div class="profile-image">
            <Picture
              src={headshotImage}
              alt="Jacek Janczura"
              class="headshot"
              widths={[150, 200, 300]}
              sizes="(max-width: 600px) 150px, 200px"
              formats={['avif', 'webp']}
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class="bio-body">
            {
              t.bio.paragraphs.map(para =>
                isListHtml(para) ? (
                  <div class="bio-text" set:html={para} />
                ) : (
                  <p class="bio-text" set:html={para} />
                ),
              )
            }
            <div class="downloads">
              <a
                href="/docs/Jacek_Janczura_CV.pdf"
                download="Jacek_Janczura_CV.pdf"
                type="application/pdf"
                class="download-link"
              >
                <Download size={16} />
                {t.downloads.cv}
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- Philosophy -->
      <div class="bio-section philosophy-section">
        <div class="philosophy-quote">
          <Quote size={24} class="quote-icon" />
          <h2>{t.philosophy.title}</h2>
        </div>
        {
          t.philosophy.paragraphs.map(para =>
            isListHtml(para) ? (
              <div class="bio-text" set:html={para} />
            ) : (
              <p class="bio-text" set:html={para} />
            ),
          )
        }
      </div>

      <!-- Career Journey -->
      <div class="bio-section">
        <h2>{t.career.title}</h2>
        {
          t.career.paragraphs.map(para =>
            isListHtml(para) ? (
              <div class="bio-text" set:html={para} />
            ) : (
              <p class="bio-text" set:html={para} />
            ),
          )
        }
      </div>

      <!-- Outside Work -->
      <div class="bio-section">
        <h2>{t.outsideWork.title}</h2>
        {t.outsideWork.paragraphs.map(para => <p class="bio-text">{para}</p>)}
      </div>
    </div>

    <!-- Skills (full width background) -->
    <div class="skills-wrapper">
      <div class="container">
        <div class="skills-section">
          <h2>{t.specializations.title}</h2>
          <div class="skills-grid">
            {
              t.specializations.categories.map((category, idx) => {
                const Icon = skillIcons[idx];
                return (
                  <div class="skill-category">
                    <div class="skill-icon">
                      <Icon size={24} />
                    </div>
                    <h3>{category.title}</h3>
                    <ul class="skills-list">
                      {category.items.map(item => (
                        <li>{item}</li>
                      ))}
                    </ul>
                  </div>
                );
              })
            }
          </div>
        </div>
      </div>
    </div>

    <!-- Timeline -->
    <div class="container content">
      <div class="timeline-section">
        <h2>{t.timeline.title}</h2>
        <div class="timeline">
          {
            t.timeline.items.map(item => (
              <div class="timeline-item">
                <div class="timeline-marker">
                  <div class="timeline-dot" />
                </div>
                <div class="timeline-content">
                  <div class="timeline-date">{item.date}</div>
                  <h3>{item.title}</h3>
                  <p class="timeline-company">{item.company}</p>
                  {isListHtml(item.description) ? (
                    <div class="timeline-desc" set:html={item.description} />
                  ) : (
                    <p class="timeline-desc">{item.description}</p>
                  )}
                  {item.hasReference && (
                    <p class="employer-reference">
                      <a
                        href="/docs/EmployerReference-Jacek.pdf"
                        download="EmployerReference-Jacek.pdf"
                        type="application/pdf"
                        class="download-link"
                      >
                        <Download size={16} />
                        {item.referenceText}
                      </a>
                    </p>
                  )}
                </div>
              </div>
            ))
          }
        </div>
      </div>

      <!-- Awards & Honors -->
      <div class="awards-section">
        <h2>{t.awards.title}</h2>
        <div class="awards-grid">
          {
            t.awards.items.map(award => (
              <div class={`award-card ${award.type}`}>
                <div class="award-icon">
                  {award.type === 'featured' ? (
                    <Award size={24} />
                  ) : (
                    <GraduationCap size={24} />
                  )}
                </div>
                <div class="award-content">
                  <h3>{award.title}</h3>
                  <p class="award-subtitle">{award.subtitle}</p>
                  <p class="award-date">{award.date}</p>
                  <p class="award-description">{award.description}</p>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Hero */
  .about-hero {
    padding: var(--space-8) 0;
    background: linear-gradient(
      135deg,
      var(--bg) 0%,
      oklch(from var(--primary) l c h / 0.05) 30%,
      oklch(from var(--accent) l c h / 0.03) 60%,
      var(--muted) 100%
    );
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .about-hero::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: radial-gradient(
      ellipse at top left,
      oklch(from var(--primary) l c h / 0.08) 0%,
      transparent 50%
    );
    pointer-events: none;
    z-index: 0;
  }

  .about-hero .container {
    position: relative;
    z-index: 1;
  }

  .about-hero h1 {
    font-size: var(--font-size-hero);
    margin-bottom: var(--space-3);
    background: linear-gradient(
      135deg,
      var(--text) 0%,
      var(--primary) 50%,
      var(--text) 100%
    );
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    background-size: 200% auto;
    animation: gradient-shift 8s ease infinite;
  }

  @keyframes gradient-shift {
    0%,
    100% {
      background-position: 0% center;
    }
    50% {
      background-position: 100% center;
    }
  }

  .about-subtitle {
    font-size: var(--font-size-xl);
    background: linear-gradient(135deg, var(--primary) 0%, var(--accent) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    margin-top: var(--space-2);
    font-weight: var(--font-weight-bold);
    font-style: italic;
  }

  /* Content area */
  .about-content {
    padding: var(--space-8) 0;
    background: linear-gradient(
      180deg,
      var(--bg) 0%,
      oklch(from var(--muted) l c h / 0.3) 50%,
      var(--bg) 100%
    );
  }

  /* Bio sections */
  .bio-section {
    margin-bottom: var(--space-7);
    padding-bottom: var(--space-6);
    position: relative;
  }

  .bio-section::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 60px;
    height: 2px;
    background: linear-gradient(90deg, var(--primary), var(--accent));
    border-radius: 1px;
  }

  .bio-section:last-of-type::after {
    display: none;
  }

  .bio-section h2 {
    margin-bottom: var(--space-4);
    font-size: var(--font-size-xl);
    color: var(--text);
    font-weight: var(--font-weight-bold);
    position: relative;
  }

  .bio-text {
    font-size: var(--font-size-base);
    line-height: 1.75;
    margin-bottom: var(--space-4);
    color: var(--text);
  }

  /* Bio intro layout - photo beside text on desktop */
  .bio-layout {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-6);
    align-items: start;
  }

  .profile-image {
    position: sticky;
    top: calc(64px + var(--space-4));
  }

  .headshot {
    width: 180px;
    height: 180px;
    border-radius: 50%;
    object-fit: cover;
    object-position: center top;
    border: 3px solid transparent;
    background:
      linear-gradient(var(--bg), var(--bg)) padding-box,
      linear-gradient(135deg, var(--primary), var(--accent), var(--primary))
        border-box;
    box-shadow:
      0 4px 20px oklch(from var(--primary) l c h / 0.15),
      var(--shadow-1);
    transition:
      transform 0.3s ease,
      box-shadow 0.3s ease;
  }

  .headshot:hover {
    transform: scale(1.05);
    box-shadow:
      0 6px 30px oklch(from var(--primary) l c h / 0.25),
      var(--shadow-2);
  }

  .downloads {
    display: flex;
    margin-top: var(--space-4);
  }

  .download-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-3);
    background: var(--muted);
    border: 1px solid var(--border);
    border-radius: var(--radius-m);
    color: var(--primary);
    text-decoration: none;
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-bold);
    transition: all 0.3s ease;
  }

  .download-link svg {
    flex-shrink: 0;
  }

  .download-link:hover {
    background: linear-gradient(135deg, var(--primary) 0%, var(--accent) 100%);
    color: white;
    border-color: var(--primary);
    transform: translateY(-2px);
    box-shadow: 0 4px 12px oklch(from var(--primary) l c h / 0.3);
    text-decoration: none;
  }

  /* Philosophy section */
  .philosophy-section {
    background: linear-gradient(
      135deg,
      oklch(from var(--primary) l c h / 0.03) 0%,
      oklch(from var(--accent) l c h / 0.02) 100%
    );
    border-radius: var(--radius-l);
    padding: var(--space-6);
    border-left: 3px solid var(--primary);
  }

  .philosophy-section::after {
    display: none;
  }

  .philosophy-section + .bio-section {
    margin-top: var(--space-7);
  }

  .philosophy-quote {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-4);
  }

  .philosophy-quote h2 {
    margin-bottom: 0;
  }

  :global(.quote-icon) {
    color: var(--primary);
    opacity: 0.5;
    flex-shrink: 0;
  }

  /* Skills section */
  .skills-wrapper {
    background: var(--muted);
    padding: var(--space-7) 0;
    margin: var(--space-6) 0;
    position: relative;
  }

  .skills-wrapper::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(
      90deg,
      transparent,
      var(--primary),
      var(--accent),
      var(--primary),
      transparent
    );
    opacity: 0.3;
  }

  .skills-section h2 {
    margin-bottom: var(--space-6);
    text-align: center;
    font-size: var(--font-size-2xl);
    color: var(--text);
    font-weight: var(--font-weight-bold);
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: var(--space-5);
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .skill-category {
    background: var(--bg);
    padding: var(--space-5);
    border-radius: var(--radius-l);
    border: 1px solid var(--border);
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
  }

  .skill-category::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(
      90deg,
      var(--primary),
      var(--accent),
      var(--primary)
    );
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .skill-category:hover {
    border-color: oklch(from var(--primary) l c h / 0.2);
    box-shadow: var(--shadow-1);
    transform: translateY(-2px);
  }

  .skill-category:hover::before {
    opacity: 1;
  }

  .skill-icon {
    margin-bottom: var(--space-3);
    display: flex;
    justify-content: center;
    align-items: center;
    color: var(--primary);
    transition: all 0.3s ease;
  }

  .skill-category:hover .skill-icon {
    transform: scale(1.1);
    color: var(--accent);
  }

  .skill-category h3 {
    font-size: var(--font-size-base);
    color: var(--primary);
    margin-bottom: var(--space-3);
    font-weight: var(--font-weight-bold);
    text-align: center;
  }

  .skills-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .skills-list li {
    padding: var(--space-1) 0;
    border-bottom: 1px solid oklch(from var(--border) l c h / 0.5);
    font-size: var(--font-size-sm);
    line-height: 1.5;
  }

  .skills-list li:last-child {
    border-bottom: none;
  }

  /* Timeline */
  .timeline-section {
    margin: var(--space-7) 0;
  }

  .timeline-section h2 {
    margin-bottom: var(--space-6);
    text-align: center;
    font-size: var(--font-size-2xl);
    color: var(--text);
    font-weight: var(--font-weight-bold);
  }

  .timeline {
    position: relative;
    padding-left: var(--space-6);
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 7px;
    top: 8px;
    bottom: 8px;
    width: 2px;
    background: linear-gradient(
      180deg,
      var(--primary) 0%,
      var(--accent) 50%,
      oklch(from var(--primary) l c h / 0.2) 100%
    );
    border-radius: 1px;
  }

  .timeline-item {
    position: relative;
    margin-bottom: var(--space-6);
    padding-left: var(--space-5);
  }

  .timeline-item:last-child {
    margin-bottom: 0;
  }

  .timeline-marker {
    position: absolute;
    left: -19px;
    top: 6px;
  }

  .timeline-dot {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--primary) 0%, var(--accent) 100%);
    border: 3px solid var(--bg);
    box-shadow: 0 0 0 2px oklch(from var(--primary) l c h / 0.2);
    transition: all 0.3s ease;
  }

  .timeline-item:hover .timeline-dot {
    transform: scale(1.3);
    box-shadow:
      0 0 0 3px oklch(from var(--primary) l c h / 0.3),
      0 0 12px oklch(from var(--primary) l c h / 0.3);
  }

  .timeline-date {
    font-size: var(--font-size-sm);
    color: var(--primary);
    font-weight: var(--font-weight-bold);
    margin-bottom: var(--space-1);
  }

  .timeline-content h3 {
    font-size: var(--font-size-lg);
    color: var(--text);
    margin-bottom: 2px;
  }

  .timeline-company {
    font-size: var(--font-size-sm);
    color: var(--text);
    opacity: 0.7;
    margin-bottom: var(--space-2);
  }

  .timeline-desc {
    font-size: var(--font-size-sm);
    line-height: 1.6;
    margin-bottom: var(--space-2);
  }

  .timeline-desc:last-child {
    margin-bottom: 0;
  }

  .employer-reference {
    margin-top: var(--space-3);
    margin-bottom: 0;
  }

  /* Awards */
  .awards-section {
    margin-top: var(--space-7);
    margin-bottom: var(--space-8);
  }

  .awards-section h2 {
    margin-bottom: var(--space-6);
    text-align: center;
    font-size: var(--font-size-2xl);
    color: var(--text);
    font-weight: var(--font-weight-bold);
  }

  .awards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--space-5);
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .award-card {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-l);
    padding: var(--space-5);
    box-shadow: var(--shadow-1);
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
    text-align: center;
  }

  .award-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-2);
    border-color: oklch(from var(--primary) l c h / 0.3);
  }

  .award-card.featured {
    background: linear-gradient(135deg, var(--primary) 0%, var(--accent) 100%);
    color: white;
    border-color: transparent;
  }

  .award-card.featured::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.1) 0%,
      rgba(255, 255, 255, 0.05) 100%
    );
    pointer-events: none;
  }

  .award-icon {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: var(--muted);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto var(--space-3) auto;
    color: var(--primary);
    transition: all 0.3s ease;
    position: relative;
    z-index: 1;
  }

  .award-card.featured .award-icon {
    background: rgba(255, 255, 255, 0.15);
    color: white;
  }

  .award-card:hover .award-icon {
    transform: scale(1.1);
  }

  .award-content {
    position: relative;
    z-index: 1;
  }

  .award-content h3 {
    font-size: var(--font-size-lg);
    margin-bottom: var(--space-2);
    font-weight: var(--font-weight-bold);
    line-height: 1.3;
  }

  .award-card.featured .award-content h3 {
    color: white;
  }

  .award-card.scholarship .award-content h3 {
    color: var(--primary);
  }

  .award-subtitle {
    font-size: var(--font-size-sm);
    color: var(--primary);
    margin-bottom: var(--space-1);
    font-weight: var(--font-weight-bold);
  }

  .award-card.featured .award-subtitle {
    color: rgba(255, 255, 255, 0.9);
  }

  .award-date {
    font-size: var(--font-size-xs);
    color: var(--text);
    opacity: 0.6;
    margin-bottom: var(--space-2);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .award-card.featured .award-date {
    color: rgba(255, 255, 255, 0.8);
    opacity: 1;
  }

  .award-description {
    font-size: var(--font-size-sm);
    line-height: 1.6;
    opacity: 0.85;
    margin: 0;
  }

  .award-card.featured .award-description {
    color: rgba(255, 255, 255, 0.9);
    opacity: 1;
  }

  /* Responsive */
  @media (max-width: 600px) {
    .bio-layout {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .profile-image {
      display: flex;
      justify-content: center;
      position: static;
    }

    .headshot {
      width: 150px;
      height: 150px;
    }

    .downloads {
      justify-content: center;
    }

    .philosophy-section {
      padding: var(--space-4);
    }

    .skills-grid {
      grid-template-columns: 1fr;
    }

    .timeline {
      padding-left: var(--space-4);
    }

    .timeline-item {
      padding-left: var(--space-4);
    }

    .timeline-marker {
      left: -17px;
    }

    .awards-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script is:inline>
  // Ensure download links work correctly with proper filenames
  function initDownloadLinks() {
    const downloadLinks = document.querySelectorAll('.download-link[download]');

    downloadLinks.forEach(function (link) {
      const anchor = link;
      const downloadFilename = anchor.getAttribute('download');

      if (downloadFilename) {
        anchor.download = downloadFilename;

        anchor.addEventListener('click', function () {
          if (!anchor.download) {
            anchor.download = downloadFilename;
          }
        });
      }
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', function () {
      if ('requestIdleCallback' in window) {
        requestIdleCallback(initDownloadLinks, { timeout: 1000 });
      } else {
        setTimeout(initDownloadLinks, 100);
      }
    });
  } else {
    if ('requestIdleCallback' in window) {
      requestIdleCallback(initDownloadLinks, { timeout: 1000 });
    } else {
      setTimeout(initDownloadLinks, 100);
    }
  }
</script>
